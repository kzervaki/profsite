---
import ContactDetails from "./ContactDetails.astro";
import ContactForm from "./ContactForm.astro";
import GoogleMap from "./GoogleMap.astro";
import { CONFIG } from "../site-config"

// Get theme from parent if available
const siteTheme = Astro.props.theme || "theme-sage";
---

<div class="contact-section" data-theme={siteTheme}>
  <ContactDetails/>

  <section class="contact-message-section">
    <h3 class="section-title">Αποστολή Μηνύματος</h3>

    <div class="contact-grid">
      <ContactForm
        action="#"
        rounded={true}
        align="left"
        buttonText="Αποστολή"
        buttonWidth="140px"
        buttonHeight="44px"
        buttonBg="var(--color-primary, #5a7d8c)"
        buttonColor="var(--color-text-light, #ffffff)"
        buttonFontSize="1rem"
        buttonRounded={true}
        buttonHoverBg="var(--color-primary-hover, #48656f)"
        class="contact-form-component"
      />

      <GoogleMap
        embedUrl={CONFIG.googleMapLocation}
        rounded={true}
        align="right"
        class="map-component"
      />
    </div>
  </section>
</div>
