---
import LinkActive from "../components/LinkActive.astro";

const baseUrl = import.meta.env.BASE_URL || '/';
---

<nav class="site-nav" data-theme="theme-sage">
  <div class="nav-inner">
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-hidden="true"
    />

    <label
      for="nav-toggle"
      class="nav-burger"
      aria-label="Open navigation"
      aria-controls="site-navigation"
      aria-expanded="false"
    >
      <span></span>
    </label>

    <div class="nav-drawer" id="site-navigation" data-theme="theme-sage">
      <!-- Main Menu -->
      <div class="menu-panel menu-panel--main" data-panel="main">
        <ul class="menu-list">
          <li><LinkActive location="" text="Αρχική" /></li>
          <li><LinkActive location="approaches" text="Προσεγγίσεις" /></li>

          <!-- Services Trigger -->
          <li class="menu-item-with-submenu" data-desktop-dropdown-container>
            <button
              class="submenu-trigger"
              data-trigger="services"
              aria-expanded="false"
              aria-haspopup="true"
            >
              <span>Υπηρεσίες</span>
              <svg class="trigger-arrow" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
                <polyline points="4,2 8,6 4,10" fill="none" stroke="currentColor" stroke-width="1.5"/>
              </svg>
            </button>

            <!-- Desktop Dropdown (added via JS for reliability) -->
          </li>

          <li><LinkActive location="about" text="Βιογραφικό" /></li>
          <li><LinkActive location="contact" text="Επικοινωνία" /></li>
        </ul>
      </div>

      <!-- Mobile Submenu -->
      <div class="menu-panel menu-panel--submenu" data-panel="services" hidden>
        <div class="submenu-header">
          <button class="back-button" data-back="main">
            <svg width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
              <polyline points="8,2 4,6 8,10" fill="none" stroke="currentColor" stroke-width="1.5"/>
            </svg>
            <span></span>
          </button>
        </div>
        <ul class="submenu-list">
          <li><a href=`${baseUrl}/services/individual-adults`>Ατομική ενηλίκων</a></li>
          <li><a href=`${baseUrl}/services/individual-teenagers`>Ατομική εφήβων</a></li>
          <li><a href=`${baseUrl}/services/couple-therapy`>Θεραπεία ζεύγους</a></li>
          <li><a href=`${baseUrl}/services/family-therapy`>Θεραπεία οικογένειας</a></li>
          <li><a href=`${baseUrl}/services/parents-counseling`>Συμβουλευτική γονέων</a></li>
          <li><a href=`${baseUrl}/services/online-sessions`>Διαδικτυακές συνεδρίες</a></li>
        </ul>
      </div>
    </div>

    <div class="nav-overlay"></div>
  </div>
</nav>

<script>
  (function() {
    'use strict';

    // Wait for DOM to be fully ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    function init() {
      // DOM elements
      const navToggle = document.getElementById('nav-toggle');
      const navBurger = document.querySelector('.nav-burger');
      const navOverlay = document.querySelector('.nav-overlay');
      const navDrawer = document.querySelector('.nav-drawer');

      const mainPanel = document.querySelector('[data-panel="main"]');
      const servicesPanel = document.querySelector('[data-panel="services"]');
      const servicesTrigger = document.querySelector('[data-trigger="services"]');
      const backButton = document.querySelector('[data-back="main"]');
      const menuLinks = document.querySelectorAll('.menu-list a, .submenu-list a');

      let isSubmenuOpen = false;

      // Force initial state
      if (servicesPanel) {
        servicesPanel.hidden = true;
      }

      if (mainPanel) {
        mainPanel.classList.remove('menu-panel--hidden');
      }

      // Helper functions
      function openMainMenu() {
        if (!navToggle) return;
        navToggle.checked = true;
        if (navBurger) navBurger.setAttribute('aria-expanded', 'true');
        document.body.classList.add('menu-open');
      }

      function closeMainMenu() {
        if (!navToggle) return;
        navToggle.checked = false;
        if (navBurger) navBurger.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('menu-open');

        // Close submenu when closing main menu
        if (isSubmenuOpen) {
          closeSubmenu();
        }
      }

      function openSubmenu() {
        if (!mainPanel || !servicesPanel) return;

        // Hide main menu, show submenu
        mainPanel.classList.add('menu-panel--hidden');
        servicesPanel.hidden = false;
        isSubmenuOpen = true;

        if (servicesTrigger) {
          servicesTrigger.setAttribute('aria-expanded', 'true');
        }

        // Ensure drawer is open
        if (navToggle && !navToggle.checked) {
          openMainMenu();
        }
      }

      function closeSubmenu() {
        if (!mainPanel || !servicesPanel) return;

        // Show main menu, hide submenu
        mainPanel.classList.remove('menu-panel--hidden');
        servicesPanel.hidden = true;
        isSubmenuOpen = false;

        if (servicesTrigger) {
          servicesTrigger.setAttribute('aria-expanded', 'false');
        }
      }

      // Toggle main menu
      if (navToggle) {
        navToggle.addEventListener('change', function(e) {
          const isOpen = e.target.checked;

          if (navBurger) {
            navBurger.setAttribute('aria-expanded', isOpen);
          }

          if (isOpen) {
            document.body.classList.add('menu-open');
          } else {
            document.body.classList.remove('menu-open');
            if (isSubmenuOpen) {
              closeSubmenu();
            }
          }
        });
      }

      // Open submenu (mobile only)
      if (servicesTrigger) {
        servicesTrigger.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();

          if (window.innerWidth < 769) {
            openSubmenu();
          }
        });
      }

      // Back button
      if (backButton) {
        backButton.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          closeSubmenu();
        });
      }

      // Overlay click
      if (navOverlay) {
        navOverlay.addEventListener('click', function() {
          closeMainMenu();
        });
      }

      // Close menu on link click (mobile)
      if (menuLinks.length) {
        menuLinks.forEach(function(link) {
          link.addEventListener('click', function() {
            if (window.innerWidth < 769) {
              setTimeout(closeMainMenu, 150);
            }
          });
        });
      }

      // Escape key
      document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
          if (isSubmenuOpen) {
            closeSubmenu();
          } else if (navToggle && navToggle.checked) {
            closeMainMenu();
          }
        }
      });

      // DESKTOP DROPDOWN - Fixed with better hover detection
      // DESKTOP DROPDOWN - Fixed with proper DOM creation
      // DESKTOP DROPDOWN - FIXED HOVER BEHAVIOR
      function setupDesktopDropdown() {
        if (window.innerWidth < 769) return;

        const container = document.querySelector('[data-desktop-dropdown-container]');
        if (!container) return;

        // Remove any existing dropdown
        const existing = container.querySelector('.desktop-dropdown');
        if (existing) existing.remove();

        // Create dropdown element
        const dropdown = document.createElement('ul');
        dropdown.className = 'desktop-dropdown';
        dropdown.setAttribute('data-desktop-dropdown', '');

        // Create dropdown items using DOM methods
        const baseUrl = import.meta.env.BASE_URL || '/';
        const items = [
          { href: `${baseUrl}/services/individual-adults`, text: 'Ατομική ενηλίκων' },
          { href: `${baseUrl}/services/individual-teenagers`, text: 'Ατομική εφήβων' },
          { href: `${baseUrl}/services/couple-therapy`, text: 'Θεραπεία ζεύγους' },
          { href: `${baseUrl}/services/family-therapy`, text: 'Θεραπεία οικογένειας' },
          { href: `${baseUrl}/services/parents-counseling`, text: 'Συμβουλευτική γονέων' },
          { href: `${baseUrl}/services/online-sessions`, text: 'Διαδικτυακές συνεδρίες' },
        ];

        items.forEach(item => {
          const li = document.createElement('li');
          const a = document.createElement('a');
          a.href = item.href;
          a.textContent = item.text;
          li.appendChild(a);
          dropdown.appendChild(li);
        });

        container.appendChild(dropdown);

        // FIXED: Simplified hover handling - no delay on show
        let hideTimeout;

        function showDropdown() {
          clearTimeout(hideTimeout);
          dropdown.classList.add('desktop-dropdown--visible');
        }

        function hideDropdown() {
          // Small delay to allow moving mouse to dropdown
          hideTimeout = setTimeout(() => {
            dropdown.classList.remove('desktop-dropdown--visible');
          }, 150);
        }

        // Hover handlers - show immediately, hide with delay
        container.addEventListener('mouseenter', showDropdown);
        container.addEventListener('mouseleave', hideDropdown);

        dropdown.addEventListener('mouseenter', showDropdown);
        dropdown.addEventListener('mouseleave', hideDropdown);

        // Also handle clicks on the trigger for touch devices
        const trigger = container.querySelector('.submenu-trigger');
        if (trigger) {
          trigger.addEventListener('click', function(e) {
            if (window.innerWidth >= 769) {
              e.preventDefault();
              if (dropdown.classList.contains('desktop-dropdown--visible')) {
                hideDropdown();
              } else {
                showDropdown();
              }
            }
          });
        }
      }

      // Handle resize
      let resizeTimer;
      window.addEventListener('resize', function() {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(function() {
          if (window.innerWidth >= 769) {
            // Switch to desktop mode
            closeSubmenu();
            if (navToggle && navToggle.checked) {
              closeMainMenu();
            }
            setupDesktopDropdown();
          } else {
            // Switch to mobile mode
            const dropdown = document.querySelector('.desktop-dropdown');
            if (dropdown) dropdown.remove();

            // Reset mobile state
            if (servicesPanel) servicesPanel.hidden = true;
            if (mainPanel) mainPanel.classList.remove('menu-panel--hidden');
            if (servicesTrigger) servicesTrigger.setAttribute('aria-expanded', 'false');
            isSubmenuOpen = false;
          }
        }, 250);
      });

      // Initial setup based on viewport
      if (window.innerWidth >= 769) {
        setupDesktopDropdown();
      } else {
        // Ensure mobile initial state
        if (servicesPanel) servicesPanel.hidden = true;
        if (mainPanel) mainPanel.classList.remove('menu-panel--hidden');
        if (servicesTrigger) servicesTrigger.setAttribute('aria-expanded', 'false');
        isSubmenuOpen = false;
      }

      // Also run after a tiny delay to ensure everything is ready
      setTimeout(function() {
        if (window.innerWidth >= 769) {
          setupDesktopDropdown();
        }
      }, 100);
    }
  })();
</script>
