---
import LinkActive from "../components/LinkActive.astro";
---

<nav class="site-nav" data-theme="theme-sage">
  <div class="nav-inner">
    <!-- Toggle -->
    <input
      type="checkbox"
      id="nav-toggle"
      class="nav-toggle"
      aria-hidden="true"
    />

    <!-- Burger button -->
    <label
      for="nav-toggle"
      class="nav-burger"
      aria-label="Open navigation"
      aria-controls="site-navigation"
    >
      <span></span>
    </label>

    <!-- Navigation drawer / bar -->
    <ul class="nav-list" id="site-navigation" data-theme="theme-sage">
      <li><LinkActive location="" text="Αρχική" /></li>
      <li><LinkActive location="approaches" text="Προσεγγίσεις" /></li>
      <li><LinkActive location="services" text="Υπηρεσίες" /></li>
      <li><LinkActive location="about" text="Βιογραφικό" /></li>
      <li><LinkActive location="contact" text="Επικοινωνία" /></li>
    </ul>

    <!-- Overlay -->
    <div class="nav-overlay"></div>
  </div>
</nav>
