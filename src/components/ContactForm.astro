---
/**
 * Props:
 *  - action: string (form submit URL, default "#")
 *  - rounded: boolean (for inputs, default true)
 *  - align: string ("left", "right", "center", default "center")
 *  - class: string (extra classes)
 *
 *  -- Button customization --
 *  - buttonText: string ("Send")
 *  - buttonWidth: string (default "auto")
 *  - buttonHeight: string (default "44px")
 *  - buttonBg: string (default "#4a90e2")
 *  - buttonColor: string (default "#fff")
 *  - buttonFontSize: string (default "1rem")
 *  - buttonRounded: boolean (default true)
 *  - buttonHoverBg: string (default "#357ABD")
 */
const {
  action = "#",
  rounded = true,
  align = "center",
  class: extraClass = "",
  buttonText = "Send",
  buttonWidth = "auto",
  buttonHeight = "44px",
  buttonBg = "var(--color-primary, #4a90e2)",
  buttonColor = "var(--color-text-light, #fff)",
  buttonFontSize = "1rem",
  buttonRounded = true,
  buttonHoverBg = "var(--color-primary-hover, #357ABD)"
} = Astro.props;

// Generate CSS classes based on props
const formClasses = [
  "contact-form",
  align !== "center" ? `contact-form--${align}` : "",
  extraClass
].filter(Boolean).join(" ");

const inputClasses = rounded ? "contact-input contact-input--rounded" : "contact-input";
const buttonClasses = [
  "contact-button",
  buttonRounded ? "contact-button--rounded" : "",
  buttonWidth !== "auto" ? "contact-button--fixed-width" : ""
].filter(Boolean).join(" ");
---
<form
  class={formClasses}
  action={action}
  method="POST"
  data-align={align}
>
  <div class="form-field">
    <label for="name" class="field-label">Ονοματεπώνυμο</label>
    <input
      type="text"
      id="name"
      name="name"
      class={inputClasses}
      required
      placeholder="Το ονοματεπώνυμό σας"
    />
  </div>

  <div class="form-field">
    <label for="email" class="field-label">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      class={inputClasses}
      required
      placeholder="Η διεύθυνση email σας"
    />
  </div>

  <div class="form-field">
    <label for="message" class="field-label">Μήνυμα</label>
    <textarea
      id="message"
      name="message"
      rows="5"
      class={inputClasses}
      required
      placeholder="Το μήνυμά σας..."
    ></textarea>
  </div>

  <button
    type="submit"
    class={buttonClasses}
    style={`
      --btn-width: ${buttonWidth};
      --btn-height: ${buttonHeight};
      --btn-bg: ${buttonBg};
      --btn-color: ${buttonColor};
      --btn-font-size: ${buttonFontSize};
      --btn-hover-bg: ${buttonHoverBg};
    `}
  >
    {buttonText}
  </button>
</form>
