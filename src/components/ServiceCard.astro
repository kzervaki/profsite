---
import Image from "./Image.astro";

const {
  title,
  description,
  href,
  image,
  imageAlt = "",
  imageWidth = "100%",
  rounded = true,
  height = "auto",
  minHeight = "auto",
} = Astro.props;

// Create a safe aria-label with proper null checks
const ariaLabel = title
  ? `${title}${description ? ` - ${description.substring(0, 60)}` : ''}${description?.length > 60 ? '...' : ''}`
  : href;

// Determine if we have image and description
const hasImage = Boolean(image);
const hasDescription = Boolean(description);

// Determine card layout class based on content
let contentClass = "service-card-content";
if (!hasImage && !hasDescription) {
  contentClass += " service-card-content--title-only";
}
---

<a
  href={href}
  class="service-card"
  data-theme="theme-floral"
  aria-label={ariaLabel}
  style={`
    ${height !== 'auto' ? `height: ${height};` : ''}
    ${minHeight !== 'auto' ? `min-height: ${minHeight};` : ''}
  `}
>
  {hasImage && (
    <div class="service-card-image-wrapper">
      <Image
        src={image}
        alt={imageAlt}
        imagewidth={imageWidth}
        rounded={rounded}
      />
    </div>
  )}

  <div class={contentClass}>
    <h3 class="service-card-title">{title}</h3>
    {hasDescription && <p class="service-card-description">{description}</p>}
  </div>
</a>
