---
import { CONFIG } from "../site-config";

const {
  title = CONFIG.siteTitle ?? "Site Title",
  subtitle = CONFIG.siteSubtitle ?? "Site subtitle",
  logoSrc = null,
  logoAlt = CONFIG.siteTitle ?? "Site logo",
  homeHref = import.meta.env.BASE_URL,
  theme = "theme-floral",
} = Astro.props;

const headerTitle = title || CONFIG.siteTitle || "Site";
---

<header class="site-header" data-theme={theme}>
  <a href={homeHref} class="site-header-link" aria-label={`${headerTitle} homepage`}>
    <div class="site-header-inner">
      {logoSrc && (
        <div class="site-header-logo">
          <img src={logoSrc} alt={logoAlt} />
        </div>
      )}

      <div class="site-header-banner">
        <h1 class="site-header-title">{headerTitle}</h1>

        <div class="site-header-subtitle-group">
          <div class="site-header-subtitle">
            <span class="subtitle-part">Ψυχολόγος ΜΑ</span>
            <span class="subtitle-sep" aria-hidden="true">·</span>
            <span class="subtitle-part">Κοινωνική Λειτουργός</span>
          </div>

          <div class="site-header-subtitle">
            <span class="subtitle-part">{CONFIG.specialtySystemic}</span>
            <span class="subtitle-sep" aria-hidden="true">·</span>
            <span class="subtitle-part">{CONFIG.specialtyDialectic}</span>
          </div>
        </div>
      </div>
    </div>
  </a>
</header>
