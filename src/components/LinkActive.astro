---
const isActive = (path) => Astro.url.pathname === path;

export interface Props {
  location: string;
  text: string;
}

const { location, text } = Astro.props;
const baseUrl = import.meta.env.BASE_URL || '/';
---

<a href=`${baseUrl}/${location}` class={isActive(`${baseUrl}/${location}`) ? "active" : ""}>
  {text}
</a>
