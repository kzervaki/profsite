---
/**
 * Props:
 *  - embedUrl: string (required) -> Google Maps iframe URL
 *  - address: string (optional, for display)
 *  - rounded: boolean (optional, default true)
 *  - align: string (optional, "left", "right", "center", default "center")
 *  - class: string (optional, extra CSS classes)
 */
const {
  embedUrl,
  address = "",
  rounded = true,
  align = "center",
  class: extraClass = ""
} = Astro.props;

// Wrapper style for alignment
let wrapperStyle = "";
if (align === "left") wrapperStyle = "margin-right: var(--space-md); margin-bottom: var(--space-md);";
else if (align === "right") wrapperStyle = "margin-left: var(--space-md); margin-bottom: var(--space-md);";
else wrapperStyle = "margin: var(--space-md) auto;"; // center
---
<div class={`map-container ${extraClass}`} style={wrapperStyle}>
  {address && <p class="map-address">{address}</p>}
  <div class="map-frame">
    <iframe
      src={embedUrl}
      class={`map-iframe ${rounded ? "map-iframe--rounded" : ""}`}
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Google Maps location"
    ></iframe>
  </div>
</div>
