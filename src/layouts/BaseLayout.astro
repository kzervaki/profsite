---
import SiteNav from "../components/SiteNav.astro";
import SiteHeader from "../components/SiteHeader.astro"
import SiteFooter from "../components/SiteFooter.astro"
import { CONFIG } from "../site-config"

interface Props {
  title?: string;   // optional manual override
  faviconSize?: string; // optional favicon size
}

const { title, faviconSize = "32x32" } = Astro.props;

const segments = Astro.url.pathname
  .split("/")
  .filter(Boolean);

const formatSegment = (segment: string) => segment
  .replace(/-/g, " ")
  .replace(/\b\w/g, (c) => c.toUpperCase());

const breadcrumbTitle = segments.length > 0
  ? segments.map(formatSegment).join(" · ")
  : "";

const pageSuffix = title || breadcrumbTitle;

const pageTitle = pageSuffix
  ? `${pageSuffix} · ${CONFIG.fullName} – ${CONFIG.profession}`
  : `${CONFIG.fullName} – ${CONFIG.profession}`;

const logoSrc = `${import.meta.env.BASE_URL}/images/logo-kzervaki.png`;
---

<!DOCTYPE html>
<html lang="en">

  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" href={logoSrc} sizes={faviconSize} />

    <!-- Global styles -->
    <link rel="stylesheet" href={`${import.meta.env.BASE_URL}/styles/global.css`}>
  </head>

  <body>
    <SiteHeader
      logoSrc={logoSrc}
    />
    <SiteNav />

    <main class="site-main" data-theme="theme-sage">
      <slot />
    </main>

    <SiteFooter />
    <!-- Navigation behavior (auto-close + focus trap) -->
    <script src="/scripts/site-nav.js" defer></script>
  </body>

</html>
